POSTGRES_DB=real_business_suite
POSTGRES_USER=rbs
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://rbs:change-me@localhost:5432/real_business_suite?schema=public
JWT_SECRET=replace-with-at-least-32-random-characters
NODE_ENV=development
# Hosting providers usually inject PORT automatically. API_PORT is the local fallback.
API_PORT=4000
# Use one URL locally. In production you may use comma-separated allowed origins.
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_CURRENCY=PGK
NEXT_PUBLIC_CURRENCY_LOCALE=en-PG

# Email delivery
# Local safe testing: keep EMAIL_DRY_RUN=true so queued emails are marked sent without contacting a provider.
EMAIL_DRY_RUN=true
# Production Resend delivery: set EMAIL_DRY_RUN=false and provide both values below.
RESEND_API_KEY=
EMAIL_FROM="Real Business Suite <no-reply@example.com>"

# Billing / subscriptions
# Keep these blank for the Free plan or local private testing.
BILLING_CURRENCY=PGK
BILLING_CURRENCY_LOCALE=en-PG
BILLING_STARTER_PRICE_MONTHLY=99
BILLING_BUSINESS_PRICE_MONTHLY=249
BILLING_PRO_PRICE_MONTHLY=499
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
